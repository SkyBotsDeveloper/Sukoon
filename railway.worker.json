{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "bot-core/Dockerfile",
    "watchPatterns": [
      "bot-core/**",
      "railway.json",
      "railway.worker.json"
    ]
  },
  "deploy": {
    "startCommand": "/bin/sh -lc 'APP_MODE=worker bot-core'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
