{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/telegram/webhook/route.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "TELEGRAM_BOT_TOKEN": "@telegram-bot-token",
    "TELEGRAM_WEBHOOK_SECRET": "@telegram-webhook-secret",
    "BOT_USERNAME": "@bot-username"
  }
}
