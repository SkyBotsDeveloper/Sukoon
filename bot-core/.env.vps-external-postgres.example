APP_ENV=production
# When using docker-compose, bot-core-web and bot-core-worker override APP_MODE
# for their own containers. Leave this as-is unless you run the binary directly.
APP_MODE=all
APP_ADDR=:8080

# Recommended durable primary database:
# - DATABASE_URL: runtime URL (pooled or standard provider URL)
# - MIGRATE_DATABASE_URL: direct URL for migrate/admin tasks when available
DATABASE_URL=postgresql://app_user:replace-me@ep-example-pooler.us-east-1.aws.neon.tech/sukoon?sslmode=require
MIGRATE_DATABASE_URL=postgresql://app_user:replace-me@ep-example.us-east-1.aws.neon.tech/sukoon?sslmode=require

# Optional pool tuning. Keep values close to the defaults unless your provider
# or VPS sizing calls for a change.
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=2
DATABASE_MAX_CONN_LIFETIME=1h
DATABASE_MAX_CONN_IDLE_TIME=15m

# Keep hot-state local to the VPS. When using docker-compose, valkey:6379 is
# correct. If running bot-core directly on the VPS host, use 127.0.0.1:6379.
REDIS_ADDR=valkey:6379
REDIS_URL=
REDIS_PASSWORD=
REDIS_DB=0

WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL=100ms

TELEGRAM_BASE_URL=https://api.telegram.org
TELEGRAM_REQUEST_TIMEOUT=5s
TELEGRAM_MAX_RETRIES=3
TELEGRAM_INITIAL_BACKOFF=750ms

PUBLIC_WEBHOOK_BASE_URL=https://bot.example.com
BOT_OWNER_USER_IDS=

PRIMARY_BOT_SLUG=primary
PRIMARY_BOT_DISPLAY_NAME=Sukoon
PRIMARY_BOT_TOKEN=
PRIMARY_BOT_WEBHOOK_KEY=
PRIMARY_BOT_WEBHOOK_SECRET=
PRIMARY_BOT_USERNAME=
