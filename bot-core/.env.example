APP_ENV=development
# When using docker-compose, bot-core-web and bot-core-worker override APP_MODE
# for their own containers. Leave this as-is unless you run the binary directly.
APP_MODE=all
APP_ADDR=:8080
PUBLIC_WEBHOOK_BASE_URL=
# Dev default points at the local compose Postgres service.
# Production recommended model:
# - DATABASE_URL = external Postgres runtime URL
# - MIGRATE_DATABASE_URL = direct Postgres URL for migrations/admin tasks
DATABASE_URL=postgres://sukoon:sukoon@postgres:5432/sukoon?sslmode=disable
# Optional: override only for migrations if your provider gives a separate direct URL.
MIGRATE_DATABASE_URL=
# Optional Postgres pool tuning for higher-latency external databases.
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=2
DATABASE_MAX_CONN_LIFETIME=1h
DATABASE_MAX_CONN_IDLE_TIME=15m
# Keep Redis/Valkey close to the bot runtime for hot-path speed.
REDIS_ADDR=valkey:6379
REDIS_URL=
REDIS_PASSWORD=
REDIS_DB=0
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL=100ms
TELEGRAM_BASE_URL=https://api.telegram.org
TELEGRAM_REQUEST_TIMEOUT=5s
TELEGRAM_MAX_RETRIES=3
TELEGRAM_INITIAL_BACKOFF=750ms
BOT_OWNER_USER_IDS=
PRIMARY_BOT_SLUG=primary
PRIMARY_BOT_DISPLAY_NAME=Sukoon
PRIMARY_BOT_TOKEN=
PRIMARY_BOT_WEBHOOK_KEY=
PRIMARY_BOT_WEBHOOK_SECRET=
PRIMARY_BOT_USERNAME=
